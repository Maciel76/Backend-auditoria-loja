# Database Configuration
# MongoDB Atlas Example: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<database>?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/auditoria

# Server Configuration
PORT=3000

# Environment
NODE_ENV=development

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Frontend URL
FRONTEND_URL=https://auditoria-loja.vercel.app

# CORS — URLs do frontend (sem barra no final, separar por vírgula)
CORS_ORIGINS=https://auditoria-loja.vercel.app,https://auditorias.freeddns.org,http://localhost:5173